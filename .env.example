PORT=8787
ALLOWED_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Enterprise deployments must use LDAPS with certificate validation.
LDAP_URL=ldaps://192.168.100.12:636
LDAP_BASE_DN=DC=aqma,DC=corp
LDAP_BIND_DN=CN=LDAP Bind,CN=Users,DC=aqma,DC=corp
LDAP_BIND_PASSWORD=replace-with-readonly-bind-password
LDAP_LOGIN_DOMAIN=aqma.com
LDAP_TLS_REJECT_UNAUTHORIZED=true
# Local-only escape hatch for a lab DC without LDAPS. Never set true in production.
LDAP_ALLOW_INSECURE=false

# Optional LDAP group gates. Separate multiple DNs with semicolons.
# APP_ACCESS_GROUP_DN restricts login to members. Empty allows any valid LDAP user.
# ADMIN_LDAP_GROUP_DN can read all tickets.
# DIRECTORY_READ_GROUP_DN can read the team directory endpoint.
APP_ACCESS_GROUP_DN=
ADMIN_LDAP_GROUP_DN=CN=AQMA Board Admins,CN=Users,DC=aqma,DC=corp
DIRECTORY_READ_GROUP_DN=CN=AQMA Board Directory Readers,CN=Users,DC=aqma,DC=corp

# Generate at least 32 random bytes, for example: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-bytes
SESSION_COOKIE_NAME=aqma_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_SECONDS=28800
API_RATE_LIMIT_PER_MINUTE=240
UPLOAD_RATE_LIMIT_PER_MINUTE=20

# Supabase backend persistence. Use the Project URL and service_role key from Supabase.
# Keep the service role key only on the backend server; never expose it in Vercel frontend variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Frontend build-time API URL. Leave empty in local dev to match the browser hostname.
VITE_AUTH_API_URL=
# Development only. Never enable this in a shared or production deployment.
VITE_LOCAL_DEV_BYPASS=false
