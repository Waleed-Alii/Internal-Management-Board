PORT=8787
ALLOWED_ORIGIN=http://127.0.0.1:5173

# Current DC accepts LDAP from the internal network. Switch to ldaps://192.168.100.12:636 after the DC certificate/TLS handshake is fixed for Node.
LDAP_URL=ldap://192.168.100.12:389
LDAP_BASE_DN=DC=aqma,DC=corp
LDAP_BIND_DN=CN=LDAP Bind,CN=Users,DC=aqma,DC=corp
LDAP_BIND_PASSWORD=replace-with-readonly-bind-password
LDAP_LOGIN_DOMAIN=aqma.com
LDAP_TLS_REJECT_UNAUTHORIZED=true

JWT_SECRET=replace-with-long-random-secret
